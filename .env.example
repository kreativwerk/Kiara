# Kiara configuration (copy to .env and adjust)

# Base directory for the SQLite database and stored attachments.
KIARA_DATA_DIR=./data

# Fernet key used to encrypt IMAP passwords at rest.
# Leave empty to let Kiara generate and persist one in .kiara_key automatically.
KIARA_SECRET_KEY=

# Maximum number of emails fetched per account per sync run (0 = unlimited).
KIARA_MAX_FETCH=0
